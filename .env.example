APP_NAME=PharmaNP
PHARMANP_VERSION=
PHARMANP_RELEASE_CHANNEL=Stable
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost/pharmanp
APP_TIMEZONE=Asia/Kathmandu

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local/shared-hosting default. Copy this file to .env and fill real credentials.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pharmanp
DB_USERNAME=root
DB_PASSWORD=

# Local tunnel to cPanel MySQL demo DB:
# ssh -N -L 3307:127.0.0.1:3306 pratiknp
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3307

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
PHARMANP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PHARMANP_JWT_ISSUER="${APP_URL}"
PHARMANP_JWT_AUDIENCE=pharmanp-api
PHARMANP_JWT_SECRET=
PHARMANP_JWT_TTL=1440

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

OCR_SPACE_API_KEY=
OCR_SPACE_ENDPOINT=https://api.ocr.space/parse/image
OCR_UPLOAD_MAX_KB=10240
OCR_SPACE_MAX_KB=1024

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PHARMANP_API_BASE_URL=
VITE_PHARMANP_STANDALONE=false
VITE_PHARMANP_AUTH_MODE=token
VITE_PHARMANP_API_TOKEN=
