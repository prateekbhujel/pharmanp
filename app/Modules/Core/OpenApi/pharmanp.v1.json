{
  "openapi": "3.0.3",
  "info": {
    "title": "PharmaNP API",
    "version": "1.0.4",
    "description": "PharmaNP ERP API. Same-domain React uses session cookies and CSRF. Standalone React, Swagger, and mobile clients can use PharmaNP API tokens or signed JWT tokens during development."
  },
  "servers": [
    {
      "url": "/api/v1",
      "description": "Same-domain Laravel API"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    },
    {
      "sessionCookie": []
    },
    {
      "csrfHeader": []
    }
  ],
  "paths": {
    "/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate and optionally issue a PharmaNP bearer token",
        "security": [],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": { "type": "string", "format": "email" },
                  "password": { "type": "string", "format": "password" },
                  "remember": { "type": "boolean" },
                  "issue_token": { "type": "boolean", "description": "Return a PharmaNP bearer token for standalone clients." },
                  "device_name": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Authenticated" },
          "422": { "$ref": "#/components/responses/ValidationError" }
        }
      }
    },
    "/auth/logout": {
      "post": {
        "tags": ["Auth"],
        "summary": "Logout current session or revoke current bearer token",
        "responses": {
          "200": { "description": "Logged out" },
          "401": { "$ref": "#/components/responses/Unauthenticated" }
        }
      }
    },
    "/me": {
      "get": {
        "tags": ["Core"],
        "summary": "Current authenticated user",
        "responses": {
          "200": {
            "description": "Current user context"
          },
          "401": {
            "description": "Unauthenticated"
          }
        }
      }
    },
    "/modules": {
      "get": {
        "tags": ["Core"],
        "summary": "Registered backend/frontend module catalog",
        "responses": {
          "200": {
            "description": "Module catalog"
          }
        }
      }
    },
    "/dashboard/summary": {
      "get": {
        "tags": ["Dashboard"],
        "summary": "Tenant-scoped dashboard metrics",
        "parameters": [
          {
            "name": "from_date",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "to_date",
            "in": "query",
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "medical_representative_id",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Dashboard metrics"
          }
        }
      }
    },
    "/inventory/products": {
      "get": {
        "tags": ["Inventory"],
        "summary": "Server-side product list",
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "minimum": 1 } },
          { "name": "per_page", "in": "query", "schema": { "type": "integer", "minimum": 5, "maximum": 100 } },
          { "name": "search", "in": "query", "schema": { "type": "string" } },
          { "name": "sort_field", "in": "query", "schema": { "type": "string", "enum": ["name", "product_code", "hs_code", "sku", "barcode", "mrp", "reorder_level", "stock_on_hand", "created_at", "updated_at"] } },
          { "name": "sort_order", "in": "query", "schema": { "type": "string", "enum": ["asc", "desc"] } },
          { "name": "company_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "division_id", "in": "query", "schema": { "type": "integer" } },
          { "name": "is_active", "in": "query", "schema": { "type": "boolean" } },
          { "name": "deleted", "in": "query", "schema": { "type": "boolean" } }
        ],
        "responses": {
          "200": {
            "description": "Paginated product collection"
          }
        }
      },
      "post": {
        "tags": ["Inventory"],
        "summary": "Create product",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/ProductWrite"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Product created"
          },
          "422": {
            "description": "Validation failed"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "sessionCookie": {
        "type": "apiKey",
        "in": "cookie",
        "name": "pharmanp_session"
      },
      "csrfHeader": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-TOKEN"
      },
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT or PharmaNP API token"
      }
    },
    "responses": {
      "Unauthenticated": {
        "description": "Authentication is required."
      },
      "Forbidden": {
        "description": "The authenticated user is not allowed to perform this action."
      },
      "ValidationError": {
        "description": "Validation failed.",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "message": {
                  "type": "string"
                },
                "errors": {
                  "type": "object",
                  "additionalProperties": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "schemas": {
      "ApiResponseEnvelope": {
        "type": "object",
        "required": ["status", "code", "message", "data"],
        "properties": {
          "status": {
            "type": "string",
            "enum": ["success", "error"],
            "example": "success"
          },
          "code": {
            "type": "integer",
            "example": 200
          },
          "message": {
            "type": "string",
            "example": "Records retrieved successfully."
          },
          "data": {
            "nullable": true,
            "description": "Resource object, collection, or null for command-only responses."
          },
          "links": {
            "$ref": "#/components/schemas/PaginationLinks"
          },
          "meta": {
            "$ref": "#/components/schemas/PaginationMeta"
          }
        },
        "example": {
          "status": "success",
          "code": 200,
          "message": "Products retrieved successfully.",
          "data": [
            {
              "id": 1,
              "name": "Paracetamol 500",
              "product_code": "ITEM-00001",
              "hs_code": "3004.90",
              "stock_on_hand": 120
            }
          ],
          "links": {
            "first": "https://pharmanp.example.test/api/v1/inventory/products?page=1",
            "last": "https://pharmanp.example.test/api/v1/inventory/products?page=8",
            "prev": null,
            "next": "https://pharmanp.example.test/api/v1/inventory/products?page=2"
          },
          "meta": {
            "current_page": 1,
            "from": 1,
            "last_page": 8,
            "path": "https://pharmanp.example.test/api/v1/inventory/products",
            "per_page": 15,
            "to": 15,
            "total": 120
          }
        }
      },
      "PaginationLinks": {
        "type": "object",
        "nullable": true,
        "properties": {
          "first": { "type": "string", "nullable": true },
          "last": { "type": "string", "nullable": true },
          "prev": { "type": "string", "nullable": true },
          "next": { "type": "string", "nullable": true }
        }
      },
      "PaginationMeta": {
        "type": "object",
        "nullable": true,
        "properties": {
          "current_page": { "type": "integer" },
          "from": { "type": "integer", "nullable": true },
          "last_page": { "type": "integer" },
          "path": { "type": "string" },
          "per_page": { "type": "integer", "example": 15 },
          "to": { "type": "integer", "nullable": true },
          "total": { "type": "integer" }
        }
      },
      "ProductWrite": {
        "type": "object",
        "required": ["name", "company_id", "unit_id", "mrp", "purchase_price", "selling_price", "reorder_level"],
        "properties": {
          "name": { "type": "string", "maxLength": 180 },
          "sku": { "type": "string", "nullable": true },
          "barcode": { "type": "string", "nullable": true },
          "product_code": { "type": "string", "nullable": true },
          "hs_code": { "type": "string", "nullable": true },
          "company_id": { "type": "integer" },
          "manufacturer_id": { "type": "integer", "nullable": true },
          "division_id": { "type": "integer", "nullable": true },
          "unit_id": { "type": "integer" },
          "group_name": { "type": "string", "nullable": true },
          "generic_name": { "type": "string", "nullable": true },
          "manufacturer_name": { "type": "string", "nullable": true },
          "packaging_type": { "type": "string", "nullable": true },
          "keywords": { "type": "string", "nullable": true },
          "description": { "type": "string", "nullable": true },
          "strength": { "type": "string", "nullable": true },
          "mrp": { "type": "number" },
          "purchase_price": { "type": "number" },
          "selling_price": { "type": "number" },
          "reorder_level": { "type": "integer" },
          "is_active": { "type": "boolean" },
          "image": { "type": "string", "format": "binary", "nullable": true }
        }
      }
    }
  },
  "tags": [
    { "name": "Auth" },
    { "name": "Core" },
    { "name": "Dashboard" },
    { "name": "Inventory" },
    { "name": "Purchase" },
    { "name": "Sales" },
    { "name": "Accounting" },
    { "name": "Field Force" },
    { "name": "Reports" },
    { "name": "Setup" }
  ]
}
